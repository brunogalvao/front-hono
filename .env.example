# Configuração do Supabase
# Obtenha em: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# URL da API (api-hono)
# Em desenvolvimento: deixe comentado — o proxy do Vite redireciona automaticamente
# Em produção: defina a URL do deployment da api-hono no Vercel
# VITE_API_URL=https://api-hono-jet.vercel.app
